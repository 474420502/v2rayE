# Web app API base path used by browser requests
# Keep as /api when using Next rewrite proxy below.
NEXT_PUBLIC_API_BASE=/api

# Optional: backend host for proxying /api/* requests.
# When set, Next.js rewrites /api/* -> ${V2RAYN_BACKEND_URL}/api/*
# Example:
# V2RAYN_BACKEND_URL=http://127.0.0.1:18000
V2RAYN_BACKEND_URL=
